{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "C:/Users/Tofame/AppData/Local/Programs/gortex/gortex.exe hook --mode=enrich",
            "statusMessage": "Layering Gortex graph context onto tool output...",
            "timeout": 3000,
            "type": "command"
          }
        ],
        "matcher": "Read|Grep|Glob"
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "C:/Users/Tofame/AppData/Local/Programs/gortex/gortex.exe hook --mode=enrich",
            "statusMessage": "Injecting Gortex orientation snapshot...",
            "timeout": 3000,
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "C:/Users/Tofame/AppData/Local/Programs/gortex/gortex.exe hook --mode=enrich",
            "statusMessage": "Enriching with Gortex graph context...",
            "timeout": 3000,
            "type": "command"
          }
        ],
        "matcher": "Read|Grep|Glob|Task|Bash|Edit|Write|mcp__gortex__read_file|mcp__gortex__get_editing_context"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "C:/Users/Tofame/AppData/Local/Programs/gortex/gortex.exe hook --mode=enrich",
            "statusMessage": "Loading Gortex graph orientation...",
            "timeout": 3000,
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "C:/Users/Tofame/AppData/Local/Programs/gortex/gortex.exe hook --mode=enrich",
            "statusMessage": "Running Gortex post-task diagnostics...",
            "timeout": 5000,
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "C:/Users/Tofame/AppData/Local/Programs/gortex/gortex.exe hook --mode=enrich",
            "statusMessage": "Surfacing relevant Gortex symbols...",
            "timeout": 3000,
            "type": "command"
          }
        ]
      }
    ]
  }
}